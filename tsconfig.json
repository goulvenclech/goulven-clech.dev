{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*", "src/pages/.well-known/**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"moduleResolution": "Bundler",
		"types": ["astro/env"],
		"paths": {
			"$src/*": ["./src/*"],
			"$components/*": ["./src/components/*"],
			"$layouts/*": ["./src/layouts/*"],
			"$assets/*": ["./src/assets/*"]
		}
	}
}
