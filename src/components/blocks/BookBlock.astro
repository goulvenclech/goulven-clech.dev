---
// @ts-ignore - Please EleventyFetch type your shit 🙏
import EleventyFetch from "@11ty/eleventy-fetch"
import Block from "../Block.astro"
import { probeImageSize, resolveRedirectChain } from "../../imageUtils"

/**
 * Used to present a book as a card, also a link to Google Shopping that book.
 * @param {string} isbn - What's this exciting book's ISBN?
 * @param {string} authors - Override the authors returned by the Open Library API.
 */
interface Props {
	isbn: string
	/** Unused since covers are no longer cropped, kept so existing MDX still type-checks. */
	focusY?: number
	authors?: string
}

const { isbn, authors } = Astro.props

/**
 * Await fetch function, to the Open Library Api
 * TO DO : handle errors !
 */
const userData: any = EleventyFetch(
	`https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&jscmd=details&format=json`,
	{
		duration: "1d",
		type: "json",
	},
)

// Got what what we needed 💰 See response format ->
// https://openlibrary.org/dev/docs/api/books
const result = await userData

const book = result[`ISBN:${isbn}`]

// Cover URL for the book — resolve redirects so Astro's image pipeline gets a direct URL
const coverUrl = await resolveRedirectChain(
	`https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`,
)

// Open Library covers vary in ratio, probe the real one so the layout doesn't
// shift when the browser loads the file. 2:3 is only a fallback.
const coverSize = (await probeImageSize(coverUrl)) ?? {
	width: 600,
	height: 900,
}
---

<Block
	image={coverUrl}
	to={book.info_url}
	imageWidth={coverSize.width}
	imageHeight={coverSize.height}
>
	<h3
		id={book.details.title}
		class="my-0 line-clamp-2 leading-8 text-ellipsis sm:line-clamp-1"
	>
		{book.details.title}
	</h3>
	<ul class="flex flex-col">
		<li>
			By {
				authors ??
					book.details.authors.map((author: any) => author.name).join(" & ")
			}
		</li>
		<li>
			{book.details.publishers.join(" & ")} ({
				new Date(book.details.publish_date).getFullYear()
			})
		</li>
		<li>
			<abbr title="International Standard Book Number">ISBN</abbr>: {
				book.details.isbn_13
			}
		</li>
	</ul>
</Block>
