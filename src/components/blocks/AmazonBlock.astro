---
import Block from "./Block.astro"
import { parseAmazonImageSize } from "./amazonUtils"

/**
 * Used to present an Amazon product as a card, also a link that product.
 * [WORK IN PROGRESS]
 */
interface Props {
	id: string
	name: string
	brand: string
	img: string
	price: string
	rating: number
	ratings_total: string
	focusY?: number
}

const { id, name, brand, img, price, rating, ratings_total, focusY } =
	Astro.props

const imageDimensions = parseAmazonImageSize(img)
const AMAZON_FALLBACK_SIZE = 1500
---

<Block
	image={img}
	to={`https://www.amazon.fr/gp/product/${id}/`}
	imageFocusY={focusY}
	imageWidth={imageDimensions?.width ?? AMAZON_FALLBACK_SIZE}
	imageHeight={imageDimensions?.height ?? AMAZON_FALLBACK_SIZE}
>
	<h3
		id={name}
		class="my-0 line-clamp-2 leading-relaxed text-ellipsis sm:line-clamp-1"
	>
		{name}
	</h3>
	<ul class="m-0 flex list-none flex-col p-0">
		<li>
			By {brand}
		</li>
		<li>
			{price}
		</li>
		<li>
			{
				[...Array(Math.round(rating))].map(() => (
					<i class="fas fa-star text-xs" />
				))
			} ({ratings_total}
			reviews)
		</li>
	</ul>
</Block>
