---
import Block from "../Block.astro"
import { parseAmazonImageSize } from "./amazonUtils"
import { probeImageSize } from "../../imageUtils"

/**
 * Used to present an Amazon product as a card, also a link that product.
 * [WORK IN PROGRESS]
 */
interface Props {
	id: string
	name: string
	brand: string
	img: string
	price: string
	rating: number
	ratings_total: string
	/** Unused since images are no longer cropped, kept so existing MDX still type-checks. */
	focusY?: number
}

const { id, name, brand, img, price, rating, ratings_total } = Astro.props

// The `_SL{n}_` URL hint only encodes the longest edge, so it can't give a
// trustworthy aspect ratio — probe the real dimensions and only fall back
// to the (square) hint if the fetch fails.
const probedDimensions = await probeImageSize(img)
const imageDimensions = probedDimensions ?? parseAmazonImageSize(img)
const AMAZON_FALLBACK_SIZE = 1500
---

<Block
	image={img}
	to={`https://www.amazon.fr/gp/product/${id}/`}
	imageWidth={imageDimensions?.width ?? AMAZON_FALLBACK_SIZE}
	imageHeight={imageDimensions?.height ?? AMAZON_FALLBACK_SIZE}
>
	<h3
		id={name}
		class="my-0 line-clamp-2 leading-relaxed text-ellipsis sm:line-clamp-1"
	>
		{name}
	</h3>
	<ul class="m-0 flex list-none flex-col p-0">
		<li>
			By {brand}
		</li>
		<li>
			{price}
		</li>
		<li>
			{
				[...Array(Math.round(rating))].map(() => (
					<i class="fas fa-star text-xs" />
				))
			} ({ratings_total}
			reviews)
		</li>
	</ul>
</Block>
