---
import ReturnHome from "$components/ReturnHome.astro"
import Layout from "$layouts/Layout.astro"
import { ratingLabels } from "$components/catalogue/reviewUtils"
import { getClient } from "$src/db"
import {
	buildListItems,
	computeListProgress,
	type ListEntry,
	type ReviewInfo,
} from "$src/listProgress"
import listData from "$src/data/letterboxd-list.json"

const pageTitle = "List progress"
const LIST_NAME = "Movies everyone should watch at least once"
const LIST_URL =
	"https://letterboxd.com/fcbarcelona/list/movies-everyone-should-watch-at-least-once/"

const entries = listData as unknown as ListEntry[]

const reviews = new Map<number, ReviewInfo>()
try {
	// Newest first, so the first row seen for a film is its latest review.
	const result = await getClient().execute(
		`SELECT source_id, source_name, rating
		   FROM reviews
		  WHERE source = 'TMDB_MOVIE'
		  ORDER BY inserted_at DESC`,
	)
	for (const row of result.rows as unknown as {
		source_id: string
		source_name: string
		rating: number
	}[]) {
		const id = Number(row.source_id)
		if (reviews.has(id)) continue
		reviews.set(id, {
			title: row.source_name,
			emoji: ratingLabels[row.rating]?.emoji ?? "",
		})
	}
} catch (error) {
	// The list itself is static, so degrade to "all unseen" rather than 500.
	console.error("list-progress: could not load reviews", error)
}

const progress = computeListProgress(entries, new Set(reviews.keys()))
const items = buildListItems(entries, reviews)
// Escape "<" so the serialised array can't close the <script> tag early.
const itemsJson = JSON.stringify(items).replace(/</g, "\\u003c")
---

<Layout
	title={pageTitle}
	description={`Tracking my catalogue against the "${LIST_NAME}" Letterboxd list.`}
>
	<section>
		<h1>{pageTitle}</h1>
		<p>
			How much of the <a href={LIST_URL}>{LIST_NAME}</a> Letterboxd list I've watched,
			matched against my <a href="/catalogue">catalogue</a> by TMDB id.
		</p>
		<p>
			<strong>{progress.seenCount} / {progress.total}</strong> watched ({
				progress.percent
			}%).
		</p>
		<div
			class="my-4 h-4 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700"
			role="progressbar"
			aria-valuenow={progress.percent}
			aria-valuemin={0}
			aria-valuemax={100}
		>
			<div
				class="h-full rounded-full bg-green-600"
				style={`width: ${progress.percent}%`}
			>
			</div>
		</div>
		{
			progress.untracked.length > 0 && (
				<p class="text-sm opacity-70">
					{progress.untracked.length} entries are TV series or have no TMDB
					movie link, so they aren't tracked.
				</p>
			)
		}
		<p>
			<ReturnHome />
		</p>
	</section>

	<section>
		<form class="mb-5 grid grid-cols-2 gap-5 text-xs sm:text-sm">
			<div class="col-span-2 flex items-center gap-3">
				<i class="fas fa-search mr-1.5"></i>
				<input
					id="query"
					type="text"
					placeholder="Search by title"
					class="w-full truncate border-b-[0.1rem] border-dotted whitespace-nowrap outline-hidden"
				/>
			</div>

			<select id="sort-filter" class="border-b-[0.1rem] border-dotted">
				<option value="year-asc" selected>🗓️ oldest first</option>
				<option value="year-desc">🗓️ newest first</option>
			</select>

			<select id="status-filter" class="border-b-[0.1rem] border-dotted">
				<option value="all" selected>🎬 all films</option>
				<option value="seen">✅ watched</option>
				<option value="unseen">◻️ not seen</option>
			</select>
		</form>

		<div id="films-grid" class="grid grid-cols-3 gap-2 sm:grid-cols-4"></div>
		<button id="load-more" class="button" type="button" hidden>Load more</button
		>

		<noscript>
			<p>This progress grid needs JavaScript to filter and sort.</p>
		</noscript>
	</section>

	<script
		type="application/json"
		id="list-items"
		is:inline
		set:html={itemsJson}
	/>

	<script>
		import {
			filterListItems,
			sortListItems,
			type ListItem,
			type ListSort,
			type ListStatus,
		} from "../../listProgress"

		const PAGE_SIZE = 100

		const dataEl = document.getElementById("list-items")
		const items: ListItem[] = dataEl
			? JSON.parse(dataEl.textContent || "[]")
			: []

		const grid = document.getElementById("films-grid") as HTMLDivElement
		const queryInput = document.getElementById("query") as HTMLInputElement
		const sortSelect = document.getElementById(
			"sort-filter",
		) as HTMLSelectElement
		const statusSelect = document.getElementById(
			"status-filter",
		) as HTMLSelectElement
		const loadMore = document.getElementById("load-more") as HTMLButtonElement

		let shown = PAGE_SIZE

		function label(item: ListItem): string {
			return item.year ? `${item.name} (${item.year})` : item.name
		}

		function placeholderFor(item: ListItem): HTMLSpanElement {
			const span = document.createElement("span")
			span.className =
				"flex h-full w-full items-center justify-center p-2 text-center text-xs"
			span.textContent = label(item)
			return span
		}

		function cardFor(item: ListItem): HTMLAnchorElement {
			const link = document.createElement("a")
			link.href = item.href
			link.title = label(item)
			link.className =
				"no-icon bg-alt-light relative aspect-3/4 overflow-hidden rounded"
			if (!item.seen) {
				link.classList.add("opacity-50", "grayscale")
				link.target = "_blank"
				link.rel = "noopener"
			}

			if (item.poster) {
				const img = document.createElement("img")
				img.src = item.poster
				img.alt = item.name
				img.loading = "lazy"
				// Drop the referrer to dodge Letterboxd's CDN hotlink blocks.
				img.referrerPolicy = "no-referrer"
				img.className = "h-full w-full object-cover"
				img.addEventListener("error", () =>
					img.replaceWith(placeholderFor(item)),
				)
				link.appendChild(img)
			} else {
				link.appendChild(placeholderFor(item))
			}

			if (item.emoji) {
				const badge = document.createElement("span")
				badge.className = "absolute top-1 right-1 text-lg drop-shadow-md"
				badge.textContent = item.emoji
				link.appendChild(badge)
			}
			return link
		}

		function currentView(): ListItem[] {
			return sortListItems(
				filterListItems(items, {
					query: queryInput.value,
					status: statusSelect.value as ListStatus,
				}),
				sortSelect.value as ListSort,
			)
		}

		function render(): void {
			const view = currentView()
			grid.replaceChildren(...view.slice(0, shown).map(cardFor))
			loadMore.hidden = shown >= view.length
		}

		function reset(): void {
			shown = PAGE_SIZE
			render()
		}

		let debounce: ReturnType<typeof setTimeout>
		queryInput.addEventListener("input", () => {
			clearTimeout(debounce)
			debounce = setTimeout(reset, 200)
		})
		sortSelect.addEventListener("change", reset)
		statusSelect.addEventListener("change", reset)
		loadMore.addEventListener("click", () => {
			shown += PAGE_SIZE
			render()
		})

		render()
	</script>
</Layout>
