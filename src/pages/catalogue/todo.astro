---
import ReturnHome from "$components/ReturnHome.astro"
import Layout from "$layouts/Layout.astro"
import { ratingLabels } from "$components/catalogue/reviewUtils"
import { getClient } from "$src/db"
import {
	buildTodoItems,
	computeTodoProgress,
	computeTodoStats,
	formatTodoStats,
	type TodoList,
	type TodoReview,
	type TodoEmotion,
} from "$src/catalogueTodo"

const pageTitle = "To-do"

const modules = import.meta.glob<{ default: TodoList }>(
	"/src/data/lists/*.json",
	{ eager: true },
)
const lists = Object.values(modules)
	.map((module) => module.default)
	.sort((a, b) => a.title.localeCompare(b.title))

// Latest review per reviewed id, per source, plus an id → emotion lookup.
const doneBySource = new Map<string, Map<string, string>>()
const reviewsBySource = new Map<string, Map<string, TodoReview>>()
const emotionsById = new Map<string, TodoEmotion>()
try {
	const client = getClient()

	const emotionRows = await client.execute(
		"SELECT id, emoji, name FROM emotions WHERE is_deleted = false",
	)
	for (const row of emotionRows.rows as unknown as {
		id: number | string
		emoji: string
		name: string
	}[])
		emotionsById.set(String(row.id), { emoji: row.emoji, name: row.name })

	for (const source of new Set(lists.map((list) => list.source))) {
		const result = await client.execute({
			sql: `SELECT source_id, rating, emotions FROM reviews WHERE source = ? ORDER BY inserted_at DESC`,
			args: [source],
		})
		const done = new Map<string, string>()
		const reviews = new Map<string, TodoReview>()
		for (const row of result.rows as unknown as {
			source_id: string
			rating: number
			emotions: string
		}[]) {
			const id = String(row.source_id)
			if (done.has(id)) continue // keep only the latest review per entry
			done.set(id, ratingLabels[row.rating]?.emoji ?? "")
			reviews.set(id, {
				rating: row.rating,
				emotions: JSON.parse(row.emotions ?? "[]") as number[],
			})
		}
		doneBySource.set(source, done)
		reviewsBySource.set(source, reviews)
	}
} catch (error) {
	// The lists are static, so degrade to "nothing done" rather than 500.
	console.error("todo: could not load reviews", error)
}

const views = lists.map((list) => {
	const items = buildTodoItems(list, doneBySource.get(list.source) ?? new Map())
	return {
		id: list.id,
		title: list.title,
		description: list.description,
		url: list.url ?? null,
		items,
		progress: computeTodoProgress(items),
		stats: computeTodoStats(
			items,
			reviewsBySource.get(list.source) ?? new Map<string, TodoReview>(),
			emotionsById,
		),
	}
})

const initial = views[0]
// Escape "<" so the serialised data can't close the <script> tag early.
const viewsJson = JSON.stringify(views).replace(/</g, "\\u003c")

// Each option keeps its original views index as its value, so the client's
// listIndex (read off the select value) still resolves to the right view.
const INACTIVE = new Set([
	"mario-marathon",
	"pokemon-marathon",
	"sniper-elite-marathon",
	"studio-ghibli-films",
	"wes-anderson-films",
])
const listOptions = views.map((view, index) => ({ view, index }))
const activeOptions = listOptions.filter(({ view }) => !INACTIVE.has(view.id))
const inactiveOptions = listOptions.filter(({ view }) => INACTIVE.has(view.id))
---

<Layout
	title={pageTitle}
	description="Tracking my catalogue against curated to-do lists — films to watch, games to play."
>
	<section>
		<h1>{pageTitle}</h1>
		<p>
			Lists I'm slowly working my way through for my <a href="/catalogue"
				>catalogue</a
			>. Pick one below.
		</p>
		<p>
			<ReturnHome />
		</p>
	</section>

	<section>
		<select
			id="list-select"
			class="w-full border-b-[0.1rem] border-dotted text-sm"
		>
			<optgroup label="active">
				{
					activeOptions.map(({ view, index }) => (
						<option value={index}>{view.title}</option>
					))
				}
			</optgroup>
			<optgroup label="inactive">
				{
					inactiveOptions.map(({ view, index }) => (
						<option value={index}>{view.title}</option>
					))
				}
			</optgroup>
		</select>

		<p class="mt-3 mb-2 text-sm opacity-80">
			<span id="list-description">{initial.description}</span>{" "}
			<a id="list-source-link" href={initial.url ?? "#"}>Source</a>
		</p>

		<p
			id="list-stats"
			class="-mt-1 mb-2 text-sm opacity-80"
			hidden={!initial.stats}
			set:html={initial.stats ? formatTodoStats(initial.stats) : ""}
		/>

		<div class="mb-3 flex items-center gap-3 text-xs sm:text-sm">
			<div
				id="todo-progressbar"
				class="bg-alt-light dark:bg-alt-dark h-2 flex-1 overflow-hidden rounded-full"
				role="progressbar"
				aria-valuemin={0}
				aria-valuemax={100}
				aria-valuenow={initial.progress.percent}
			>
				<div
					id="todo-bar"
					class="bg-primary h-full rounded-full"
					style={`width: ${initial.progress.percent}%`}
				>
				</div>
			</div>
			<span class="whitespace-nowrap opacity-70">
				<span id="todo-done">{initial.progress.doneCount}</span>/<span
					id="todo-total">{initial.progress.total}</span
				> · <span id="todo-percent">{initial.progress.percent}</span>%
			</span>
		</div>

		<form class="mb-5 grid grid-cols-2 gap-5 text-xs sm:text-sm">
			<div class="col-span-2 flex items-center gap-3">
				<div class="group flex flex-1 items-center">
					<i class="fas fa-search group-has-focus:text-primary mr-1.5"></i>
					<input
						id="query"
						type="text"
						placeholder="Search by title"
						class="group-has-focus:text-primary w-full truncate border-b-[0.1rem] border-dotted whitespace-nowrap outline-hidden placeholder:truncate"
					/>
				</div>
				<reset-button
					defaults='{"query":"","sort-filter":"year-asc","status-filter":"all"}'
				></reset-button>
			</div>

			<select id="sort-filter" class="border-b-[0.1rem] border-dotted">
				<option value="year-asc" selected>🗓️ oldest first</option>
				<option value="year-desc">🗓️ newest first</option>
			</select>

			<select id="status-filter" class="border-b-[0.1rem] border-dotted">
				<option value="all" selected>🎬 all</option>
				<option value="done">✅ done</option>
				<option value="todo">◻️ to do</option>
			</select>
		</form>

		<div id="todo-grid" class="grid grid-cols-3 gap-2 sm:grid-cols-4"></div>
		<empty-state id="todo-empty" hidden></empty-state>
		<button id="load-more" class="button" type="button" hidden>Load more</button
		>

		<side-note>
			Images and datas are fetched from <a href="https://igdb.com/"
				><abbr title="The Internet Game Database">IGDB</abbr></a
			> for video games, <a href="https://boardgamegeek.com"
				><abbr title="Board Game Geek">BGG</abbr></a
			> for board games, <a href="https://themoviedb.org/"
				><abbr title="The Movie DataBase">TMDB</abbr></a
			> for movies and shows, <a href="https://spotify.com/">Spotify</a> for albums,
			and <a href="https://openlibrary.org/">Open Library</a> for books. Their licenses
			apply.
		</side-note>

		<noscript>
			<p>This to-do grid needs JavaScript to filter and sort.</p>
		</noscript>
	</section>

	<script
		type="application/json"
		id="todo-views"
		is:inline
		set:html={viewsJson}
	/>

	<script>
		import "../../components/ResetButton.ts"
		import "../../components/EmptyState.ts"
		import {
			filterTodoItems,
			sortTodoItems,
			formatTodoStats,
			type TodoItem,
			type TodoProgress,
			type TodoStats,
			type TodoSort,
			type TodoStatus,
		} from "../../catalogueTodo"
		import {
			buildTodoParams,
			resolveTodoState,
		} from "../../components/catalogue/todoFilters"
		import { toQueryString } from "../../components/catalogue/catalogueFilters"

		interface View {
			id: string
			title: string
			description: string
			url: string | null
			items: TodoItem[]
			progress: TodoProgress
			stats: TodoStats | null
		}

		const PAGE_SIZE = 100

		const dataEl = document.getElementById("todo-views")
		const views: View[] = dataEl ? JSON.parse(dataEl.textContent || "[]") : []

		const listSelect = document.getElementById(
			"list-select",
		) as HTMLSelectElement
		const descriptionEl = document.getElementById("list-description")!
		const sourceLink = document.getElementById(
			"list-source-link",
		) as HTMLAnchorElement
		const statsEl = document.getElementById(
			"list-stats",
		) as HTMLParagraphElement
		const doneEl = document.getElementById("todo-done")!
		const totalEl = document.getElementById("todo-total")!
		const percentEl = document.getElementById("todo-percent")!
		const bar = document.getElementById("todo-bar")!
		const progressbar = document.getElementById("todo-progressbar")!
		const grid = document.getElementById("todo-grid") as HTMLDivElement
		const queryInput = document.getElementById("query") as HTMLInputElement
		const sortSelect = document.getElementById(
			"sort-filter",
		) as HTMLSelectElement
		const statusSelect = document.getElementById(
			"status-filter",
		) as HTMLSelectElement
		const loadMore = document.getElementById("load-more") as HTMLButtonElement
		const emptyEl = document.getElementById("todo-empty") as HTMLElement

		let listIndex = 0
		let shown = PAGE_SIZE

		function label(item: TodoItem): string {
			return item.year ? `${item.name} (${item.year})` : item.name
		}

		function placeholderFor(item: TodoItem): HTMLSpanElement {
			const span = document.createElement("span")
			span.className =
				"flex h-full w-full items-center justify-center p-2 text-center text-xs"
			span.textContent = label(item)
			return span
		}

		function cardFor(item: TodoItem): HTMLAnchorElement {
			const link = document.createElement("a")
			link.href = item.href
			link.title = label(item)
			link.className =
				"no-icon bg-alt-light relative aspect-3/4 overflow-hidden rounded"
			if (!item.done) {
				link.classList.add("opacity-60", "grayscale")
				link.target = "_blank"
				link.rel = "noopener"
			}

			if (item.poster) {
				const img = document.createElement("img")
				img.src = item.poster
				img.alt = item.name
				img.loading = "lazy"
				// Drop the referrer to dodge CDN hotlink blocks.
				img.referrerPolicy = "no-referrer"
				img.className = "h-full w-full object-cover"
				img.addEventListener("error", () =>
					img.replaceWith(placeholderFor(item)),
				)
				link.appendChild(img)
			} else {
				link.appendChild(placeholderFor(item))
			}

			if (item.emoji) {
				const badge = document.createElement("span")
				badge.className = "absolute top-1 right-1 text-lg drop-shadow-md"
				badge.textContent = item.emoji
				link.appendChild(badge)
			}
			return link
		}

		function renderMeta(view: View): void {
			descriptionEl.textContent = view.description
			if (view.url) sourceLink.href = view.url
			sourceLink.hidden = !view.url
			if (view.stats) statsEl.innerHTML = formatTodoStats(view.stats)
			statsEl.hidden = !view.stats
			doneEl.textContent = String(view.progress.doneCount)
			totalEl.textContent = String(view.progress.total)
			percentEl.textContent = String(view.progress.percent)
			bar.style.width = `${view.progress.percent}%`
			progressbar.setAttribute("aria-valuenow", String(view.progress.percent))
		}

		function renderGrid(view: View): void {
			if (!view) return
			const items = sortTodoItems(
				filterTodoItems(view.items, {
					query: queryInput.value,
					status: statusSelect.value as TodoStatus,
				}),
				sortSelect.value as TodoSort,
			)
			grid.replaceChildren(...items.slice(0, shown).map(cardFor))
			emptyEl.hidden = items.length > 0
			loadMore.hidden = shown >= items.length
		}

		function render(): void {
			const view = views[listIndex]
			if (!view) return
			renderMeta(view)
			renderGrid(view)
		}

		const defaultList = views[0]?.id ?? ""

		function syncUrl(): void {
			const params = buildTodoParams(
				{
					list: views[listIndex]?.id ?? "",
					query: queryInput.value,
					sort: sortSelect.value,
					status: statusSelect.value,
				},
				{ list: defaultList },
			)
			history.replaceState(
				null,
				"",
				`${location.pathname}${toQueryString(params)}`,
			)
		}

		listSelect.addEventListener("change", () => {
			listIndex = Number(listSelect.value)
			shown = PAGE_SIZE
			syncUrl()
			render()
		})

		let debounce: ReturnType<typeof setTimeout>
		queryInput.addEventListener("input", () => {
			clearTimeout(debounce)
			debounce = setTimeout(() => {
				shown = PAGE_SIZE
				syncUrl()
				renderGrid(views[listIndex])
			}, 200)
		})
		for (const select of [sortSelect, statusSelect]) {
			select.addEventListener("change", () => {
				shown = PAGE_SIZE
				syncUrl()
				renderGrid(views[listIndex])
			})
		}
		loadMore.addEventListener("click", () => {
			shown += PAGE_SIZE
			renderGrid(views[listIndex])
		})
		// <reset-button> restores control values without firing input/change.
		queryInput.form?.addEventListener("reset-filters", () => {
			shown = PAGE_SIZE
			syncUrl()
			renderGrid(views[listIndex])
		})
		// A single-field form submits on Enter; keep the URL state instead.
		queryInput.form?.addEventListener("submit", (event) =>
			event.preventDefault(),
		)

		const state = resolveTodoState(
			new URLSearchParams(location.search),
			views.map((view) => view.id),
		)
		queryInput.value = state.query
		sortSelect.value = state.sort
		statusSelect.value = state.status
		listIndex = Math.max(
			0,
			views.findIndex((view) => view.id === state.list),
		)
		listSelect.value = String(listIndex)
		// Notify <reset-button> of the restored control values.
		queryInput.form?.dispatchEvent(new Event("change", { bubbles: true }))
		render()
		syncUrl()
	</script>
</Layout>
