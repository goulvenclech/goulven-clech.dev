---
import { getCollection, render, type CollectionEntry } from "astro:content"
import Layout from "$layouts/Layout.astro"
import { isEntryPublished, isFirstAprilEntry } from "src/blogUtils"
import EntryHeader from "$components/EntryHeader.astro"

import TableOfContent from "$components/TableOfContent.astro"
/**
 * Create a page for each blog entries, display frontmatter
 * informations & the content.
 */
export async function getStaticPaths() {
	const blogEntries: CollectionEntry<"blog">[] = await getCollection("blog")

	const allEntries = blogEntries.map((e) => ({ id: e.id, date: e.data.date }))

	return blogEntries.map((entry) => ({
		params: {
			entry: entry.id,
		},
		props: {
			entry,
			isAprilCools: isFirstAprilEntry(
				{ id: entry.id, date: entry.data.date },
				allEntries,
			),
		},
	}))
}

const { entry, isAprilCools } = Astro.props
const { Content, headings } = await render(entry)
---

<Layout
	title={entry.data.title}
	description={entry.data.abstract_clean || entry.data.abstract}
	img={entry.data.image?.src}
>
	<section>
		<EntryHeader
			title={entry.data.title}
			abstract={entry.data.abstract}
			date={entry.data.date}
			isAprilCools={isAprilCools}
			isPublished={isEntryPublished(entry.data.published, true)}
			timeMachine={entry.data.timeMachine}
		/>
		{headings.length > 0 && <TableOfContent headings={headings} />}

		<section id="entry">
			<Content />
		</section>
	</section>
	<style is:global>
		@reference "$assets/base.css";

		.frame.is-terminal .header {
			display: none;
		}

		.expressive-code {
			@apply my-5;
		}

		/* Drop cap */
		#entry > p:first-of-type::first-letter {
			/* Font size is 2.5 times the text size * 1.625 (line height) */
			/* Margin top verticaly align the drop cap with the two text lines */
			@apply float-left mt-px mr-1 -mb-5 text-[calc(16px*1.625*2.5)] leading-none italic sm:text-[calc(18px*1.625*2.5)];
			/* Let's be fancy with some OpenType features */
			font-feature-settings: "ss01", "ss02", "ss03", "ss04", "ss05", "swsh";
		}

		/* Fix for Chrome and Safari — don't ask why I need this, I'll cry */
		/* Use @supports to discriminate Firefox and olders browsers */
		@supports (initial-letter: 5) or (-webkit-initial-letter: 5) {
			#entry > p:first-of-type::first-letter {
				@apply -mt-2.75;
			}
		}

		/* If an entry start with a title (so it appear in the TOC)
    hide it for a better reading flow */
		#entry h2:first-child {
			@apply invisible m-0 h-0;
		}

		#entry > ul,
		#entry > ol {
			@apply list-inside;
		}

		/* I use a manicule as a list marker, in the future I'll use "indent hanging"
     but it's not supported in Chrome yet */
		#entry > ul {
			@apply my-5 list-none indent-0 sm:indent-[-27.58px];
		}

		#entry > ul > li::before {
			content: "☞";
			@apply mr-2;
		}

		#entry > ol {
			@apply mb-5;
		}

		#entry > ol > li,
		#entry > ul > li {
			@apply my-2.5 ml-0;
		}

		@media screen(sm) {
			#entry > ul,
			#entry > ol {
				@apply list-outside;
			}
		}
	</style>
</Layout>
